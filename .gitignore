# --- Secrets: never commit ---
.env

# --- Run data: ignore contents, keep the folder skeleton ---
data/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/results/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# --- Tooling / test caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Editors / OS ---
.idea/
.vscode/
.DS_Store